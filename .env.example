# ──────────────────────────────────────────────────────────────────────────
# Mekgwe & Co. — environment variables
# Copy this file to `.env.local` for local dev, and add the same keys
# to the Vercel project settings for production.
# ──────────────────────────────────────────────────────────────────────────

# Public site URL — used for OpenGraph, sitemap, canonical links.
# Local dev:  http://localhost:3000
# Production: https://your-vercel-url.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub username whose public repos populate the Selected Works chapter.
NEXT_PUBLIC_GITHUB_USER=ipelengmekgwe

# Optional: a personal access token raises the GitHub API rate limit
# from 60 to 5000 requests/hour. `public_repo` scope is enough.
# Generate at https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Only needed when running scripts/push-to-github.mjs (one-off README + repo
# description sync). Classic PAT with `public_repo` scope:
# https://github.com/settings/tokens?type=classic
# Keep this separate from GITHUB_TOKEN so the running site uses minimal privilege.
GITHUB_WRITE_TOKEN=

# Resend — powers the contact form on the back cover.
# Sign up at https://resend.com (free tier: 3,000 emails/month, 100/day).
# Verify the sending domain (or use the default `onboarding@resend.dev`).
RESEND_API_KEY=
CONTACT_TO_EMAIL=mekgwei@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Comma-separated list of GitHub orgs/users whose repos should NEVER appear
# in the Selected Works feed (e.g. private freelance work).
GITHUB_EXCLUDE_OWNERS=EAMS-Technologies,FTSI-Web
